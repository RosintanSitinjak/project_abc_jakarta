# ---- OS / Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Laravel / PHP ----
/vendor/
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
composer.lock.bak

# Laravel env & secrets
.env
.env.*
!/\.env.example

# Caches / logs
/storage/*.key
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*

# Keep required folders but ignore content
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/views/.gitignore
!/bootstrap/cache/.gitignore

# ---- Frontend (Nuxt in /frontend) ----
/frontend/node_modules/
/frontend/.nuxt/
/frontend/.output/
/frontend/dist/
/frontend/.cache/
/frontend/.nitro/
/frontend/.turbo/
/frontend/.pnpm-store/

# Nuxt / Vite / general
*.log
